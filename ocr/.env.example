# === Общие ===
APP_NAME=PDF OCR Service
DEBUG=false
LOG_LEVEL=INFO

# === Безопасность путей ===
ALLOWED_BASE_PATH=/data/pdfs
MAX_FILE_SIZE_MB=200

# === Хранение результатов ===
RESULTS_DIR=/app/results
TEMP_DIR=/app/tmp

# === Redis / Celery ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Лимиты задач (секунды) — большие PDF на CPU требуют больше времени
TASK_SOFT_TIME_LIMIT=1800
TASK_TIME_LIMIT=2100

# === Docling ===
# DOCLING_ARTIFACTS_PATH=/app/models
DOCLING_USE_GPU=false
DOCLING_DO_FORMULA_ENRICHMENT=false
DOCLING_PRELOAD_MODELS=false

# === API ===
API_PREFIX=/api/v1
