POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=db
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
GIN_MODE=debug
STORE_BACKEND=postgres
LIGHTRAG_SERVICE_URL=http://lightrag:9621
OCR_SERVICE_URL=http://ocr:8000/api/v1
MAX_UPLOAD_SIZE_MB=50
AUTH_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

OCR_TEMP_DIR=/app/tmp
OCR_DOCLING_USE_GPU=false
OCR_DOCLING_DO_FORMULA_ENRICHMENT=false
OCR_DOCLING_DOCUMENT_TIMEOUT_SECONDS=180
OCR_MINERU_USE_GPU=false
OCR_MINERU_BACKEND=pipeline
OCR_MINERU_DOCUMENT_TIMEOUT_SECONDS=1800.0
MINERU_MODEL_SOURCE=huggingface
OCR_API_PREFIX=/api/v1
OCR_LOG_LEVEL=INFO

LIGHTRAG_API_KEY=

LIGHTRAG_LLM_BINDING=ollama
LIGHTRAG_LLM_BINDING_HOST=http://ollama:11434
LIGHTRAG_LLM_BINDING_API_KEY=
LIGHTRAG_LLM_MODEL=qwen3:4b-instruct
LIGHTRAG_LLM_TIMEOUT=900

LIGHTRAG_EMBEDDING_BINDING=ollama
LIGHTRAG_EMBEDDING_BINDING_HOST=http://ollama:11434
LIGHTRAG_EMBEDDING_BINDING_API_KEY=
LIGHTRAG_EMBEDDING_MODEL=bge-m3
LIGHTRAG_EMBEDDING_DIM=1024
LIGHTRAG_EMBEDDING_TOKEN_LIMIT=8192
LIGHTRAG_EMBEDDING_SEND_DIM=false
LIGHTRAG_EMBEDDING_USE_BASE64=false

LIGHTRAG_SUMMARY_LANGUAGE=Russian
LIGHTRAG_MAX_ASYNC_LLM=2
LIGHTRAG_MAX_PARALLEL_INSERT=1
LIGHTRAG_EMBEDDING_FUNC_MAX_ASYNC=2
LIGHTRAG_EMBEDDING_BATCH_NUM=4
LIGHTRAG_POSTGRES_VECTOR_INDEX_TYPE=HNSW
LIGHTRAG_POSTGRES_HNSW_M=16
LIGHTRAG_POSTGRES_HNSW_EF=200
LIGHTRAG_POSTGRES_IVFFLAT_LISTS=100
LIGHTRAG_WORKSPACE=default
