# Database Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=db
POSTGRES_SSLMODE=disable

# Backend Configuration
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
GIN_MODE=release
STORE_BACKEND=postgres
AUTH_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
APP_PUBLIC_URL=http://localhost:9689
EMAIL_VERIFICATION_TTL=15m
EMAIL_RESEND_COOLDOWN=60s
MAX_UPLOAD_SIZE_MB=50

# SMTP Configuration (Optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# OCR Service Configuration
OCR_SERVICE_URL=http://ocr:8000/api/v1
OCR_TEMP_DIR=/app/tmp
OCR_MINERU_USE_GPU=false
OCR_MINERU_BACKEND=pipeline
OCR_MINERU_DOCUMENT_TIMEOUT_SECONDS=1800.0
MINERU_MODEL_SOURCE=huggingface
OCR_API_PREFIX=/api/v1
OCR_LOG_LEVEL=INFO