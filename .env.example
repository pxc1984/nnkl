POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=db
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
GIN_MODE=debug
STORE_BACKEND=postgres
OCR_SERVICE_URL=http://localhost:8000/api/v1
MAX_UPLOAD_SIZE_MB=50
AUTH_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

OCR_TEMP_DIR=/app/tmp
OCR_DOCLING_USE_GPU=false
OCR_DOCLING_DO_FORMULA_ENRICHMENT=false
OCR_API_PREFIX=/api/v1
OCR_LOG_LEVEL=INFO

LIGHTRAG_SERVICE_URL=
LIGHTRAG_API_KEY=

LIGHTRAG_LLM_BINDING=openai
LIGHTRAG_LLM_BINDING_HOST=https://api.openai.com/v1
LIGHTRAG_LLM_BINDING_API_KEY=replace-with-openai-compatible-api-key
LIGHTRAG_LLM_MODEL=gpt-4o-mini

LIGHTRAG_EMBEDDING_BINDING=openai
LIGHTRAG_EMBEDDING_BINDING_HOST=https://api.openai.com/v1
LIGHTRAG_EMBEDDING_BINDING_API_KEY=replace-with-openai-compatible-api-key
LIGHTRAG_EMBEDDING_MODEL=text-embedding-3-large
LIGHTRAG_EMBEDDING_DIM=3072
LIGHTRAG_EMBEDDING_TOKEN_LIMIT=8192
LIGHTRAG_EMBEDDING_SEND_DIM=false
LIGHTRAG_EMBEDDING_USE_BASE64=true

LIGHTRAG_SUMMARY_LANGUAGE=Russian
LIGHTRAG_MAX_ASYNC_LLM=4
LIGHTRAG_MAX_PARALLEL_INSERT=2
LIGHTRAG_EMBEDDING_FUNC_MAX_ASYNC=8
LIGHTRAG_EMBEDDING_BATCH_NUM=16
LIGHTRAG_POSTGRES_VECTOR_INDEX_TYPE=HNSW
LIGHTRAG_POSTGRES_HNSW_M=16
LIGHTRAG_POSTGRES_HNSW_EF=200
LIGHTRAG_POSTGRES_IVFFLAT_LISTS=100
LIGHTRAG_WORKSPACE=default
