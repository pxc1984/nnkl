# Postgres (for local run; start a Postgres instance separately)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DATABASE=lightrag
POSTGRES_SSL_MODE=disable

# Storage backends
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=PGGraphStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage

# LightRAG server API key (optional)
LIGHTRAG_API_KEY=

# LLM
LLM_BINDING=openai
LLM_MODEL=gpt://<folder-id>/yandexgpt-5.1/latest
LLM_BINDING_HOST=https://ai.api.cloud.yandex.net/v1
LLM_BINDING_API_KEY=

# Embeddings
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=emb://<folder-id>/text-embeddings/latest
EMBEDDING_BINDING_HOST=https://ai.api.cloud.yandex.net/v1
EMBEDDING_BINDING_API_KEY=
EMBEDDING_DIM=1536
EMBEDDING_TOKEN_LIMIT=8192

MAX_ASYNC=2
MAX_PARALLEL_INSERT=1
EMBEDDING_FUNC_MAX_ASYNC=2
EMBEDDING_BATCH_NUM=1

SUMMARY_LANGUAGE=Russian
