# === Общие ===
APP_NAME=PDF OCR Service
DEBUG=false
LOG_LEVEL=INFO

# === Shared Postgres ===
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ocr

# === Runtime ===
TEMP_DIR=/app/tmp

# === Docling ===
# DOCLING_ARTIFACTS_PATH=/app/models
DOCLING_USE_GPU=false
DOCLING_DO_FORMULA_ENRICHMENT=false

# === API ===
API_PREFIX=/api/v1
